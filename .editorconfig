# =============================================================================
# .editorconfig — FIREWALL SYNTAXIQUE DU PROJET (Statut : LOI)
# =============================================================================
# Objectif : rendre le style C# NON NÉGOCIABLE quel que soit l'agent IA
# (Claude, Codex, Cursor...). Une violation de style = ERREUR DE BUILD.
#
# ⚠️ Ces règles ne sont bloquantes au build que parce que Directory.Build.props
#    active <EnforceCodeStyleInBuild> et <TreatWarningsAsErrors>.
#    Les deux fichiers forment UN SEUL dispositif : ne jamais en modifier un
#    sans vérifier l'autre.
#
# Ce que l'analyseur NE PEUT PAS attraper (à vérifier via AI_SOP §7) :
#   DateTime.Now / Guid.NewGuid / new Random() en simulation, itération de
#   Dictionary en simulation, using Raylib/ImGui dans Core|Systems|Data.
#   → Candidat futur : Microsoft.CodeAnalysis.BannedApiAnalyzers (ADR requis).
# =============================================================================

root = true

# -----------------------------------------------------------------------------
# TOUS FICHIERS
# -----------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,jsonc,yml,yaml,csproj,props,targets}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{cmd,bat,ps1}]
end_of_line = crlf

# -----------------------------------------------------------------------------
# C# — RÈGLES DE LANGAGE
# -----------------------------------------------------------------------------
[*.cs]

## --- Namespaces et usings -----------------------------------------------
csharp_style_namespace_declarations = file_scoped:error
dotnet_diagnostic.IDE0160.severity = error   # namespace bloc interdit
dotnet_diagnostic.IDE0161.severity = error   # file-scoped obligatoire
csharp_using_directive_placement = outside_namespace:error
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
dotnet_diagnostic.IDE0005.severity = error   # using inutile = erreur (anti-cruft IA)

## --- Types explicites (anti-ambiguïté inter-IA) --------------------------
# var UNIQUEMENT quand le type est littéralement visible à droite du '='.
csharp_style_var_for_built_in_types = false:error
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:error
dotnet_style_predefined_type_for_locals_parameters_members = true:error   # int, pas Int32
dotnet_style_predefined_type_for_member_access = true:error

## --- Structure et lisibilité --------------------------------------------
csharp_prefer_braces = true:error            # accolades TOUJOURS, même 1 ligne
dotnet_diagnostic.IDE0011.severity = error
dotnet_style_require_accessibility_modifiers = always:error   # public/private explicite
dotnet_diagnostic.IDE0040.severity = error
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:error
csharp_style_prefer_top_level_statements = false:suggestion   # Main explicite préféré
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion

## --- Code mort et hygiène (les hallucinations laissent des traces) -------
dotnet_diagnostic.IDE0051.severity = error   # membre privé jamais utilisé
dotnet_diagnostic.IDE0052.severity = error   # membre privé jamais lu
dotnet_diagnostic.IDE0059.severity = error   # assignation inutile
dotnet_diagnostic.IDE0060.severity = error   # paramètre jamais utilisé
dotnet_style_readonly_field = true:error     # champ readonly si possible
dotnet_diagnostic.IDE0044.severity = error
dotnet_diagnostic.CA1822.severity = suggestion  # membre marquable static (info, pas bloquant)

## --- Culture et globalisation (machine FR : float.Parse("0,5") = poison) -
dotnet_diagnostic.CA1304.severity = error    # ToLower sans culture
dotnet_diagnostic.CA1305.severity = error    # Parse/ToString sans IFormatProvider
dotnet_diagnostic.CA1310.severity = error    # StartsWith/Compare sans StringComparison
dotnet_diagnostic.CA1311.severity = error    # ToUpper culture-dépendant

## --- Performance (hot path du Tick) --------------------------------------
dotnet_diagnostic.CA1825.severity = error    # Array.Empty<T>() plutôt que new T[0]
dotnet_diagnostic.CA1802.severity = error    # const plutôt que static readonly si possible
dotnet_diagnostic.CA1852.severity = warning  # sceller les types internes

# -----------------------------------------------------------------------------
# C# — NOMMAGE (toute violation = IDE1006 = erreur de build)
# -----------------------------------------------------------------------------
dotnet_diagnostic.IDE1006.severity = error

## Styles
dotnet_naming_style.pascal_case.capitalization = pascal_case
dotnet_naming_style.camel_case.capitalization = camel_case
dotnet_naming_style.i_pascal_case.capitalization = pascal_case
dotnet_naming_style.i_pascal_case.required_prefix = I
dotnet_naming_style.t_pascal_case.capitalization = pascal_case
dotnet_naming_style.t_pascal_case.required_prefix = T
dotnet_naming_style.underscore_camel_case.capitalization = camel_case
dotnet_naming_style.underscore_camel_case.required_prefix = _

## Symboles
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.type_parameters.applicable_kinds = type_parameter
dotnet_naming_symbols.constant_fields.applicable_kinds = field
dotnet_naming_symbols.constant_fields.required_modifiers = const
dotnet_naming_symbols.static_readonly_fields.applicable_kinds = field
dotnet_naming_symbols.static_readonly_fields.required_modifiers = static, readonly
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private, protected, private_protected
dotnet_naming_symbols.public_fields.applicable_kinds = field
dotnet_naming_symbols.public_fields.applicable_accessibilities = public, internal, protected_internal
dotnet_naming_symbols.locals_and_params.applicable_kinds = parameter, local
dotnet_naming_symbols.local_functions.applicable_kinds = local_function
dotnet_naming_symbols.all_members.applicable_kinds = class, struct, enum, delegate, method, property, event, namespace

## Règles — ordre : du plus spécifique au plus général
# Interfaces : IPascalCase (ICommandQueue)
dotnet_naming_rule.interfaces_are_ipascal.symbols = interfaces
dotnet_naming_rule.interfaces_are_ipascal.style = i_pascal_case
dotnet_naming_rule.interfaces_are_ipascal.severity = error

# Paramètres de type : TPascalCase (TDef)
dotnet_naming_rule.type_params_are_tpascal.symbols = type_parameters
dotnet_naming_rule.type_params_are_tpascal.style = t_pascal_case
dotnet_naming_rule.type_params_are_tpascal.severity = error

# Constantes : PascalCase (TicksPerDay)
dotnet_naming_rule.constants_are_pascal.symbols = constant_fields
dotnet_naming_rule.constants_are_pascal.style = pascal_case
dotnet_naming_rule.constants_are_pascal.severity = error

# static readonly : PascalCase
dotnet_naming_rule.static_readonly_are_pascal.symbols = static_readonly_fields
dotnet_naming_rule.static_readonly_are_pascal.style = pascal_case
dotnet_naming_rule.static_readonly_are_pascal.severity = error

# Champs privés/protégés : _camelCase (_tickCount)
dotnet_naming_rule.private_fields_are_underscore_camel.symbols = private_fields
dotnet_naming_rule.private_fields_are_underscore_camel.style = underscore_camel_case
dotnet_naming_rule.private_fields_are_underscore_camel.severity = error

# Champs publics : PascalCase (les tableaux SoA : public ushort[] OwnerId)
dotnet_naming_rule.public_fields_are_pascal.symbols = public_fields
dotnet_naming_rule.public_fields_are_pascal.style = pascal_case
dotnet_naming_rule.public_fields_are_pascal.severity = error

# Variables locales et paramètres : camelCase (provinceId)
dotnet_naming_rule.locals_are_camel.symbols = locals_and_params
dotnet_naming_rule.locals_are_camel.style = camel_case
dotnet_naming_rule.locals_are_camel.severity = error

# Fonctions locales : PascalCase
dotnet_naming_rule.local_functions_are_pascal.symbols = local_functions
dotnet_naming_rule.local_functions_are_pascal.style = pascal_case
dotnet_naming_rule.local_functions_are_pascal.severity = error

# Tout le reste (classes, structs, méthodes, propriétés...) : PascalCase
dotnet_naming_rule.members_are_pascal.symbols = all_members
dotnet_naming_rule.members_are_pascal.style = pascal_case
dotnet_naming_rule.members_are_pascal.severity = error
